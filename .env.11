## TYPO3 11.5
TYPO3_BASE_VERSION=11
PHP_VERSION=8.1
DATABASE_VERSION=mariadb:10.4
COMPOSER_ROOT_VERSION=1.0.0

# TYPO3 CLI
TYPO3_CONSOLE_VERSION=7.1.0
TYPO3_CLI_COMMAND="exec typo3"

# Introduction Package & Extensions (empty = skip)
INTRODUCTION_VERSION=4.5.0
BOOTSTRAP_PACKAGE_VERSION=13.0.0
CONTAINER_VERSION=2.3.0

# Database (DDEV defaults)
TYPO3_INSTALL_DB_USER=db
TYPO3_INSTALL_DB_PASSWORD=db
TYPO3_INSTALL_DB_DBNAME=db

# Admin credentials (override in .env.local)
TYPO3_INSTALL_ADMIN_USER=""
TYPO3_INSTALL_ADMIN_PASSWORD=""

# Web server & site
TYPO3_INSTALL_WEB_SERVER_CONFIG=apache
TYPO3_INSTALL_SITE_SETUP_TYPE=no
TYPO3_INSTALL_SITE_BASE_URL="https://$PROJECT_NAME.ddev.site/"

# Packages
CREATE_PACKAGES_DIR=0
GET_T3STATIC=0

# Add-ons
INSTALL_PHPMYADMIN=0
